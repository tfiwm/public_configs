{
    "$schema": "https://opencode.ai/config.json",
    "permission": {
        "read": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "lsp": "allow",
        "skill": "allow",
        "todowrite": "allow",
        "question": "allow",
        "task": "ask",
        "external_directory": "ask",
        "websearch": "ask",
        "webfetch": "ask",
        "repo_clone": "ask",
        "repo_overview": "ask",
        "doom_loop": "ask",
        "bash": {
            "*": "ask",
            "curl *": "deny",
            "wget *": "deny",
            "sudo *": "deny",
            "chmod -R 777": "deny",
            "chmod -R 777 *": "deny",
            "rm -rf *": "deny",
            "kill": "allow",
            "kill *": "allow",
            "git *": "allow",
            "git add .": "ask",
            "git add . *": "ask",
            "git push": "ask",
            "git push *": "ask",
            "git reset --hard": "ask",
            "git reset --hard *": "ask",
            "git push --force": "ask",
            "git push --force *": "ask",
            "git push -f": "ask",
            "git push -f *": "ask",
            "flutter *": "ask",
            "flutter run": "allow",
            "flutter run *": "allow",
            "flutter build": "allow",
            "flutter build *": "allow",
            "flutter test *": "allow",
            "flutter analyze *": "allow",
            "nohup flutter run": "allow",
            "nohup flutter run *": "allow",
            "cd *": "allow",
            "ls *": "allow",
            "pwd": "allow",
            "grep": "allow",
            "find * -exec *": "ask",
            "find *": "allow",
            "head *": "allow",
            "tail *": "allow",
            "cat *": "allow",
            "bat *": "allow",
            "nohup *": "ask",
            "sh *": "ask",
            "zsh *": "ask",
            "csh *": "ask",
            "tcsh *": "ask",
            "fish *": "ask",
            "dash *": "ask",
            "ksh *": "ask",
            "node *": "ask",
            "npm *": "ask",
            "yarn *": "ask",
            "pnpm *": "ask",
            "python *": "ask",
            "python3 *": "ask",
            "pip *": "ask",
            "docker *": "ask",
            "podman *": "ask",
            "cargo *": "ask",
            "go *": "ask",
            "ruby *": "ask",
            "perl *": "ask",
            "php *": "ask",
            "make *": "ask",
            "cmake *": "ask",
            "kubectl *": "ask",
            "dotnet *": "ask",
            "java *": "ask",
            "javac *": "ask",
            "tclsh *": "ask"
        }
    }
}
